# IdeaForge Environment Configuration
# Copy to .env and adjust values as needed.

# Database
DATABASE_URL=postgres://ideaforge:ideaforge@localhost:5433/ideaforge

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Auth
JWT_SECRET=change-me-in-production-use-a-random-64-char-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Logging
RUST_LOG=ideaforge=debug,tower_http=debug
