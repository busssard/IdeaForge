#!/usr/bin/env bash
# pre-push hook — runs fmt, clippy, check, test before allowing a push.
# Enable with: git config core.hooksPath .githooks  (or scripts/install-hooks.sh)
# Skip for an emergency push with: git push --no-verify
#
# Output policy: ALL steps stay quiet on success. On failure, print only the
# lines the dev team needs: file:line, error/panic, failing test names.
# Full logs for every step live in /tmp/ideaforge-pre-push-*.log.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT/src"

if [[ -t 1 ]]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; GREEN=$'\e[32m'; RED=$'\e[31m'
    CYAN=$'\e[36m'; YELLOW=$'\e[33m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; GREEN=""; RED=""; CYAN=""; YELLOW=""; RESET=""
fi

START_TS=$(date +%s)
STEP=0
TOTAL=4
LOG_DIR="/tmp"

banner() {
    STEP=$((STEP + 1))
    printf "%b[pre-push %d/%d]%b %s " "${CYAN}${BOLD}" "$STEP" "$TOTAL" "$RESET" "$1"
}

ok() { printf "%bok%b\n" "$GREEN" "$RESET"; }
bad() { printf "%b%sFAILED%b\n" "$RED" "$BOLD" "$RESET"; }

fail() {
    local elapsed=$(( $(date +%s) - START_TS ))
    echo
    echo "${RED}${BOLD}✗ pre-push failed${RESET} after ${elapsed}s at step ${STEP}/${TOTAL}"
    echo "${DIM}  bypass (not recommended): git push --no-verify${RESET}"
    exit 1
}
trap fail ERR

echo "${BOLD}pre-push checks${RESET} ${DIM}($(basename "$REPO_ROOT") @ $(git rev-parse --abbrev-ref HEAD))${RESET}"

# --- 1. rustfmt -----------------------------------------------------------
banner "rustfmt"
FMT_LOG="$LOG_DIR/ideaforge-pre-push-fmt.log"
if cargo fmt --all -- --check > "$FMT_LOG" 2>&1; then
    ok
else
    bad
    echo "${DIM}  full log: $FMT_LOG${RESET}"
    echo "${BOLD}${RED}Files needing formatting:${RESET}"
    grep -E '^Diff in ' "$FMT_LOG" | sed -E 's|^Diff in (.*) at line ([0-9]+):|  • \1:\2|' | sort -u | head -40
    echo
    echo "${YELLOW}  fix: cargo fmt --all${RESET}"
    false
fi

# --- 2. clippy ------------------------------------------------------------
banner "clippy"
CLIPPY_LOG="$LOG_DIR/ideaforge-pre-push-clippy.log"
if ! cargo clippy --version >/dev/null 2>&1; then
    printf "%bskipped (not installed)%b\n" "$YELLOW" "$RESET"
else
    if CARGO_TERM_COLOR=never cargo clippy --workspace --all-targets --quiet \
            -- -D warnings > "$CLIPPY_LOG" 2>&1; then
        ok
    else
        bad
        echo "${DIM}  full log: $CLIPPY_LOG${RESET}"
        echo "${BOLD}${RED}Clippy issues:${RESET}"
        # Pair each `error:` / `warning:` line with the following ` --> file:line:col`.
        awk '
            /^(error|warning)(\[[^]]+\])?: / { msg = $0; next }
            /^[[:space:]]*--> / && msg != "" {
                sub(/^[[:space:]]*--> /, "", $0)
                printf "  • %s\n    %s\n", $0, msg
                msg = ""
            }
        ' "$CLIPPY_LOG" | head -80
        echo
        echo "${YELLOW}  fix the issues above, or narrow with: cargo clippy --workspace${RESET}"
        false
    fi
fi

# --- 3. cargo check -------------------------------------------------------
banner "cargo check"
CHECK_LOG="$LOG_DIR/ideaforge-pre-push-check.log"
if CARGO_TERM_COLOR=never cargo check --workspace --all-targets --quiet \
        > "$CHECK_LOG" 2>&1; then
    ok
else
    bad
    echo "${DIM}  full log: $CHECK_LOG${RESET}"
    echo "${BOLD}${RED}Compile errors:${RESET}"
    awk '
        /^error(\[[^]]+\])?: / { msg = $0; next }
        /^[[:space:]]*--> / && msg != "" {
            sub(/^[[:space:]]*--> /, "", $0)
            printf "  • %s\n    %s\n", $0, msg
            msg = ""
        }
    ' "$CHECK_LOG" | head -80
    false
fi

# --- 4. cargo test --------------------------------------------------------
banner "cargo test"
TEST_LOG="$LOG_DIR/ideaforge-pre-push-test.log"
TEST_STATUS=0
CARGO_TERM_COLOR=never cargo test --workspace --no-fail-fast --quiet \
    > "$TEST_LOG" 2>&1 || TEST_STATUS=$?

if [[ $TEST_STATUS -eq 0 ]]; then
    # Tally passed/failed across all crates for one-line summary.
    PASSED=$(awk '/^test result: ok\./ { for (i=1;i<=NF;i++) if ($i=="passed;") s+=$(i-1) } END {print s+0}' "$TEST_LOG")
    printf "%bok%b ${DIM}(%s tests)%b\n" "$GREEN" "$RESET" "$PASSED" "$RESET"
else
    bad
    echo "${DIM}  full log: $TEST_LOG${RESET}"

    # Compile errors (tests didn't even build)
    if grep -qE '^error(\[[^]]+\])?: ' "$TEST_LOG"; then
        echo "${BOLD}${RED}Compile errors:${RESET}"
        awk '
            /^error(\[[^]]+\])?: / { msg = $0; next }
            /^[[:space:]]*--> / && msg != "" {
                sub(/^[[:space:]]*--> /, "", $0)
                printf "  • %s\n    %s\n", $0, msg
                msg = ""
            }
        ' "$TEST_LOG" | head -60
    fi

    # Failing test names
    FAILED_NAMES=$(grep -E '^test .+ \.\.\. FAILED$' "$TEST_LOG" | awk '{print $2}' | sort -u || true)
    if [[ -n "$FAILED_NAMES" ]]; then
        echo "${BOLD}${RED}Failed tests:${RESET}"
        echo "$FAILED_NAMES" | sed 's/^/  • /'
        echo
        echo "${BOLD}${RED}Failure details:${RESET}"
        awk '
            /^failures:$/ { inblock = 1; next }
            inblock && /^test result:/ { inblock = 0 }
            inblock { print }
        ' "$TEST_LOG" \
            | grep -E "panicked at|assertion|^Error:|^---- .+ stdout ----" \
            | sed 's/^/  /' \
            | head -60
    fi
    false
fi

ELAPSED=$(( $(date +%s) - START_TS ))
echo
echo "${GREEN}${BOLD}✓ pre-push passed${RESET} ${DIM}(${ELAPSED}s)${RESET}"
