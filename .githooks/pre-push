#!/usr/bin/env bash
# pre-push hook — runs cargo check + cargo test before allowing a push.
# Enable with: git config core.hooksPath .githooks
# Skip for an emergency push with: git push --no-verify
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT/src"

echo "[pre-push] cargo check --workspace"
cargo check --workspace --quiet

echo "[pre-push] cargo test --workspace"
cargo test --workspace --quiet

echo "[pre-push] ok"
