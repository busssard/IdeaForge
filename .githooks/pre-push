#!/usr/bin/env bash
# pre-push hook — runs cargo check + cargo test before allowing a push.
# Enable with: git config core.hooksPath .githooks  (or scripts/install-hooks.sh)
# Skip for an emergency push with: git push --no-verify
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT/src"

# Colours (skip if not a tty)
if [[ -t 1 ]]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; GREEN=$'\e[32m'; RED=$'\e[31m'
    CYAN=$'\e[36m'; YELLOW=$'\e[33m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; GREEN=""; RED=""; CYAN=""; YELLOW=""; RESET=""
fi

START_TS=$(date +%s)
STEP=0
TOTAL=4

banner() {
    STEP=$((STEP + 1))
    echo
    echo "${CYAN}${BOLD}[pre-push ${STEP}/${TOTAL}]${RESET} ${BOLD}$1${RESET}"
    echo "${DIM}$ $2${RESET}"
}

fail() {
    local elapsed=$(( $(date +%s) - START_TS ))
    echo
    echo "${RED}${BOLD}✗ pre-push failed${RESET} after ${elapsed}s at step ${STEP}/${TOTAL}"
    echo "${DIM}  fix the failure above, or bypass with: git push --no-verify${RESET}"
    exit 1
}
trap fail ERR

echo "${BOLD}Running pre-push checks${RESET} ${DIM}(repo: $(basename "$REPO_ROOT"), branch: $(git rev-parse --abbrev-ref HEAD))${RESET}"
echo "${DIM}workspace root: $PWD${RESET}"

# 1. Format
banner "rustfmt — formatting check" "cargo fmt --all -- --check"
if ! cargo fmt --all -- --check; then
    echo "${YELLOW}  hint: run 'cargo fmt --all' to fix${RESET}"
    false
fi
echo "${GREEN}  ok${RESET}"

# 2. Clippy (warnings-as-errors). Skip if clippy isn't installed.
if cargo clippy --version >/dev/null 2>&1; then
    banner "clippy — lint check" "cargo clippy --workspace --all-targets -- -D warnings"
    cargo clippy --workspace --all-targets --quiet -- -D warnings
    echo "${GREEN}  ok${RESET}"
else
    STEP=$((STEP + 1))
    echo
    echo "${YELLOW}[pre-push ${STEP}/${TOTAL}] clippy not installed — skipping${RESET}"
fi

# 3. Type check
banner "cargo check — type check across workspace" "cargo check --workspace --all-targets"
cargo check --workspace --all-targets --quiet
echo "${GREEN}  ok${RESET}"

# 4. Test suite
banner "cargo test — running workspace tests" "cargo test --workspace"
# Capture full output; on success show only the summary line(s), on failure
# print only the FAILED test names + their panic messages + file:line info.
# Full log is always kept at /tmp/ideaforge-pre-push-test.log for debugging.
TEST_LOG="/tmp/ideaforge-pre-push-test.log"
TEST_STATUS=0
# --no-fail-fast → run the whole suite so the dev sees every failure in one go.
# CARGO_TERM_COLOR=always keeps colour in the log file; we strip it before grep.
CARGO_TERM_COLOR=never cargo test --workspace --no-fail-fast > "$TEST_LOG" 2>&1 \
    || TEST_STATUS=$?

if [[ $TEST_STATUS -eq 0 ]]; then
    # Success: print the one-line "test result: ok" lines only.
    grep -E '^test result:' "$TEST_LOG" | sed 's/^/  /' || true
    echo "${GREEN}  ok${RESET}"
else
    echo "${RED}  ${BOLD}FAILED${RESET}"
    echo "${DIM}  full log: $TEST_LOG${RESET}"
    echo

    # --- Failing test names ---
    # Lines look like:   test path::to::test_name ... FAILED
    FAILED_NAMES=$(grep -E '^test .+ \.\.\. FAILED$' "$TEST_LOG" | awk '{print $2}' | sort -u || true)
    if [[ -n "$FAILED_NAMES" ]]; then
        echo "${BOLD}${RED}Failed tests:${RESET}"
        echo "$FAILED_NAMES" | sed 's/^/  • /'
        echo
    fi

    # --- Failure details: panic messages with file:line ---
    # Cargo prints a "failures:" section at the end with each test's stdout
    # containing the panic line (e.g. `thread 'foo' panicked at src/x.rs:42:5:`).
    # Extract that block.
    echo "${BOLD}${RED}Failure details:${RESET}"
    awk '
        /^failures:$/ { inblock = 1; next }
        inblock && /^test result:/ { inblock = 0 }
        inblock { print }
    ' "$TEST_LOG" | grep -E "panicked at|assertion|Error:|thread '.+' panicked|^---- .+ stdout ----|^note: " \
                  | sed 's/^/  /' \
                  | head -80

    # --- Compile errors (if tests didn't even build) ---
    if grep -qE '^error(\[E[0-9]+\])?: ' "$TEST_LOG"; then
        echo
        echo "${BOLD}${RED}Compile errors:${RESET}"
        # Each rustc error block: the `error: ...` line + the ` --> file:line:col` line.
        grep -E '^(error(\[E[0-9]+\])?: |  --> )' "$TEST_LOG" | sed 's/^/  /' | head -60
    fi

    echo
    echo "${DIM}  (copy the above when filing a bug; full output in $TEST_LOG)${RESET}"
    false  # trigger the ERR trap
fi

ELAPSED=$(( $(date +%s) - START_TS ))
echo
echo "${GREEN}${BOLD}✓ pre-push passed${RESET} ${DIM}(${ELAPSED}s)${RESET}"
